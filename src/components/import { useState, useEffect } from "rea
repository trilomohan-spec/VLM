import { useState, useEffect } from "react";
import { Wifi, WifiOff, CheckCircle, XCircle, Loader2, X } from "lucide-react";
import { getServerUrl, setServerUrl, testServerConnection } from "@/lib/ocr";

type Status = "idle" | "testing" | "ok" | "fail";

export function ServerSettings({ onClose }: { onClose: () => void }) {
  const [url, setUrl] = useState(getServerUrl);
  const [status, setStatus] = useState<Status>("idle");

  useEffect(() => {
    // Auto-test on open if URL is already saved
    if (getServerUrl()) handleTest(getServerUrl());
  }, []);

  async function handleTest(testUrl?: string) {
    const target = (testUrl ?? url).trim();
    if (!target) return;
    setStatus("testing");
    const ok = await testServerConnection(target);
    setStatus(ok ? "ok" : "fail");
  }

  function handleSave() {
    setServerUrl(url);
    onClose();
  }

  function handleClear() {
    setUrl("");
    setServerUrl("");
    setStatus("idle");
  }

  const statusIcon = {
    idle: null,
    testing: <Loader2 className="h-4 w-4 animate-spin text-muted-foreground" />,
    ok: <CheckCircle className="h-4 w-4 text-emerald-400" />,
    fail: <XCircle className="h-4 w-4 text-red-400" />,
  }[status];

  const statusText = {
    idle: "",
    testing: "Testing connection…",
    ok: "Server reachable",
    fail: "Cannot reach server — check IP and that the server is running",
  }[status];

  return (
    <div className="fixed inset-0 z-50 flex flex-col justify-end" style={{ userSelect: "text", WebkitUserSelect: "text" }}>
      {/* Backdrop */}
      <div className="absolute inset-0 bg-black/60" onClick={onClose} />

      {/* Sheet */}
      <div className="relative bg-card border-t border-border rounded-t-2xl p-6 space-y-5">
        {/* Header */}
        <div className="flex items-center justify-between">
          <div>
            <div className="text-base font-bold">Backend Server</div>
            <div className="text-[11px] text-muted-foreground uppercase tracking-wider">
              OCR Model Connection
            </div>
          </div>
          <button onClick={onClose} className="p-2 rounded-lg hover:bg-secondary">
            <X className="h-5 w-5" />
          </button>
        </div>

        {/* Status indicator */}
        <div className="flex items-center gap-2 text-sm">
          {getServerUrl() ? (
            status === "ok" ? (
              <Wifi className="h-4 w-4 text-emerald-400" />
            ) : (
              <WifiOff className="h-4 w-4 text-muted-foreground" />
            )
          ) : (
            <WifiOff className="h-4 w-4 text-muted-foreground" />
          )}
          <span className="text-muted-foreground text-xs">
            {getServerUrl()
              ? status === "ok"
                ? "Connected to backend model"
                : "Backend model not connected — using on-device OCR"
              : "No server configured — using on-device Tesseract OCR"}
          </span>
        </div>

        {/* URL input */}
        <div className="space-y-2">
          <label className="text-xs text-muted-foreground uppercase tracking-wider">
            Server URL
          </label>
          <div className="flex gap-2 items-center bg-background border border-border rounded-lg px-3 py-3">
            <input
              value={url}
              onChange={(e) => { setUrl(e.target.value); setStatus("idle"); }}
              placeholder="http://192.168.1.100:8000"
              className="flex-1 bg-transparent text-sm focus:outline-none font-mono"
              style={{ userSelect: "text", WebkitUserSelect: "text" }}
              autoCapitalize="none"
              autoCorrect="off"
              spellCheck={false}
            />
            {statusIcon}
          </div>
          {statusText && (
            <p className={`text-xs ${status === "ok" ? "text-emerald-400" : status === "fail" ? "text-red-400" : "text-muted-foreground"}`}>
              {statusText}
            </p>
          )}
          <p className="text-[11px] text-muted-foreground">
            Enter the IP address and port of your Python OCR server running on the RTX machine.
            Both devices must be on the same Wi-Fi network.
          </p>
        </div>

        {/* Buttons */}
        <div className="flex gap-3">
          <button
            onClick={handleClear}
            className="px-4 py-2.5 rounded-lg border border-border text-sm hover:bg-secondary"
          >
            Clear
          </button>
          <button
            onClick={() => handleTest()}
            disabled={!url.trim() || status === "testing"}
            className="px-4 py-2.5 rounded-lg border border-border text-sm hover:bg-secondary disabled:opacity-40"
          >
            Test
          </button>
          <button
            onClick={handleSave}
            className="flex-1 px-4 py-2.5 rounded-lg bg-primary text-primary-foreground font-semibold text-sm hover:opacity-90"
          >
            Save
          </button>
        </div>

        {/* Safe area spacer */}
        <div style={{ paddingBottom: "env(safe-area-inset-bottom)" }} />
      </div>
    </div>
  );
}